{
  "name": "tg-tui",
  "version": "1.0.0",
  "description": "Telegram Terminal User Interface (TUI)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "tg-tui": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "build": "tsc",
    "build:exe": "npm run build && pkg . --out-path bin",
    "build:macos": "npm run build && pkg . --targets node22-macos-x64 --out-path bin/macos",
    "build:linux": "npm run build && pkg . --targets node22-linux-x64 --out-path bin/linux",
    "build:win": "npm run build && pkg . --targets node22-win-x64 --out-path bin/win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "pkg": {
    "assets": [
      "node_modules/yoga-layout-prebuilt/**/*",
      "node_modules/telegram/**/*",
      "node_modules/dotenv/**/*"
    ]
  },
  "keywords": [
    "telegram",
    "tui",
    "cli",
    "ink"
  ],
  "author": "Ryan",
  "license": "ISC",
  "dependencies": {
    "@asharahmed/qr-cli": "github:asharahmed/qr-cli",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "chalk": "^4.1.2",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "ink-box": "^1.0.0",
    "ink-divider": "^4.1.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "telegram": "^2.26.22",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "pkg": "^5.8.1"
  }
}
